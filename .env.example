# Server
PORT=3000
NODE_ENV=development

# Database adapter: typeorm | supabase | mongoose
DATABASE_ADAPTER=typeorm

# PostgreSQL (used when DATABASE_ADAPTER=typeorm or supabase)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chatbot_ai

# Supabase (used when DATABASE_ADAPTER=supabase)
# SUPABASE_URL=     # Your Supabase project URL
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SECRET_KEY=
# SUPABASE_DATABASE_URL=  # PostgreSQL connection URI from Supabase dashboard
# SUPABASE_JWKS_URL=

# MongoDB / Atlas (used when DATABASE_ADAPTER=mongoose)
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# AI Providers
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# AI defaults
DEFAULT_MODEL=google/gemini-2.0-flash-exp:free
AI_MAX_RETRIES=3

# Logging
LOG_LEVEL=info
SERVICE_NAME=chatbot-ai

# App metadata (used for OpenRouter headers)
APP_URL=http://localhost:3000
APP_NAME=Chatbot AI
