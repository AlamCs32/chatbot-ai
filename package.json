{
  "name": "chatbot_ai",
  "packageManager": "yarn@4.9.2",
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "dev": "tsx watch -r tsconfig-paths/register -r dotenv src/index.ts",
    "build": "tsc",
    "start": "node -r dotenv -r tsconfig-paths/register dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2",
    "@types/express": "^5",
    "@types/morgan": "^1",
    "@types/node": "^26.0.0",
    "@types/pg": "^8",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@google/generative-ai": "^0.24.1",
    "@langchain/anthropic": "^1.5.0",
    "@langchain/community": "^1.1.29",
    "@langchain/core": "^1.2.0",
    "@langchain/google-genai": "^2.2.0",
    "@langchain/openai": "^1.5.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "morgan": "^1.11.0",
    "openai": "^6.44.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "rotating-file-stream": "^3.2.9",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^1.0.0",
    "uuid": "^14.0.0"
  }
}
